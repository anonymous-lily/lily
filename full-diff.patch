-/// use rosa::trace::{self, Trace};
-///
-/// let my_trace = Trace {
-///     name: "my_trace".to_string(),
-///     test_input: vec![],
-///     edges: vec![1, 0, 1, 0],
-///     syscalls: vec![0, 1, 0, 1],
-/// };
